{
  "manifest_version": 3,
  "name": "Gridmarks",
  "description": "A Chrome-like bookmark surface with a denser Opera-style grid layout.",
  "version": "0.1.0",
  "permissions": ["activeTab", "bookmarks", "storage", "tabs", "tabGroups"],
  "icons": {
    "16": "icons/gridmarks-icon-16.png",
    "32": "icons/gridmarks-icon-32.png",
    "48": "icons/gridmarks-icon-48.png",
    "128": "icons/gridmarks-icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "bookmarks": "index.html"
  },
  "action": {
    "default_title": "Save to Gridmarks",
    "default_popup": "save-popup.html",
    "default_icon": {
      "16": "icons/gridmarks-icon-16.png",
      "32": "icons/gridmarks-icon-32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Option+D"
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
